# ============================================
# Augy Music Bot - Environment Configuration
# ============================================
# Copy this file to .env and fill in your values

# ============== Bot Settings ==============
# Your Discord bot token (required)
TOKEN=your_bot_token_here

# Your Discord bot client ID (required)
CLIENT_ID=your_bot_client_id

# Default command prefix
PREFIX=!

# Default language (en, es, fr, de, pt, ja, ko, zh)
DEFAULT_LANGUAGE=en

# ============== Owner Settings ==============
# Your Discord user ID(s) - Can be JSON array or comma-separated
# Example: ["123456789","987654321"] or 123456789,987654321
OWNER_IDS=["your_discord_id"]

# Single guild mode (leave empty for multi-guild)
# If set, commands will only be synced to this guild
GUILD_ID=

# ============== Logging ==============
# Channel ID for bot logs (join/leave, node status)
LOG_CHANNEL_ID=

# Channel ID for command usage logs
LOG_COMMANDS_ID=

# ============== Bot Status ==============
# Bot status: online, dnd, idle, invisible
BOT_STATUS=online

# Activity type: 0=Playing, 1=Streaming, 2=Listening, 3=Watching, 5=Competing
BOT_ACTIVITY_TYPE=2

# Activity name (what the bot is "doing")
BOT_ACTIVITY_NAME=/play | Music

# ============== Music Settings ==============
# Default volume (1-100)
DEFAULT_VOLUME=100

# Maximum queue size
MAX_QUEUE_SIZE=1000

# Maximum playlist size
MAX_PLAYLIST_SIZE=100

# ============== Database ==============
# SQLite database URL (default)
DATABASE_URL=data/augymusic.db

# PostgreSQL example (uncomment to use):
# DATABASE_URL=postgresql://user:password@localhost:5432/augymusic

# ============== Lavalink ==============
# Main Lavalink node settings
LAVALINK_HOST=localhost
LAVALINK_PORT=2333
LAVALINK_PASSWORD=youshallnotpass
LAVALINK_SECURE=false

# Additional nodes (JSON array, optional)
# Example: [{"host":"node2.example.com","port":2333,"password":"pass","identifier":"NODE2"}]
LAVALINK_NODES=

# ============== Optional Integrations ==============
# Genius API token for lyrics (optional)
GENIUS_TOKEN=

# Spotify credentials for Spotify support via LavaSrc plugin
# SPOTIFY_CLIENT_ID=
# SPOTIFY_CLIENT_SECRET=
